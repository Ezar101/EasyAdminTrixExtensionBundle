{
  "name": "ezar101/easyadmin-trix-extension-bundle",
  "type": "symfony-bundle",
  "license": "MIT",
  "description": "An extension for EasyAdmin that enriches the TextEditorField (Trix) editor with advanced features: Tables, Colors, H2/H3 headings, Underlining, ...",
  "keywords": [
    "symfony",
    "easyadmin",
    "trix",
    "wysiwyg",
    "editor",
    "text-editor",
    "table",
    "bundle",
    "extension"
  ],
  "authors": [
    {
      "name": "Ezar Affandi",
      "email": "salez.ea@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.4",
    "symfony/framework-bundle": "^6.0|^7.0|^8.0",
    "easycorp/easyadmin-bundle": "^4.0|^5.0"
  },
  "autoload": {
    "psr-4": {
      "Ezar101\\EasyAdminTrixExtensionBundle\\": "src/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": false
    }
  },
  "minimum-stability": "stable"
}
